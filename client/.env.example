# URL of the deployed backend API (Railway). Leave empty for local dev —
# Create React App's "proxy" field in package.json forwards /api to
# http://localhost:5000 automatically during development.
#
# Example for production (set this in Vercel's Environment Variables, not here):
# REACT_APP_API_URL=https://your-app.up.railway.app
REACT_APP_API_URL=
