# This app has no backend of its own — it talks directly to your deployed
# NovaStay HMS backend's public API.
#
# Local dev: point this at a locally-running HMS backend (usually
# http://localhost:4000/api/v1) or your deployed one — either works.
# Production (Vercel): set this in Vercel's Environment Variables, not here,
# e.g. https://api.curatdconcepts.com/api/v1
REACT_APP_HMS_API_URL=http://localhost:4000/api/v1
