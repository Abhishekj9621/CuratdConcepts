PORT=5000
NODE_ENV=development

# Comma-separated list of allowed frontend origins for CORS
# e.g. http://localhost:3000,https://your-app.vercel.app
CLIENT_URL=http://localhost:3000

# ── Admin Authentication ────────────────────────────────────────────────
# Username for the admin portal login
ADMIN_USERNAME=admin

# Bcrypt hash of the admin password — NEVER put a plain-text password here.
# Generate one with: node scripts/generate-password-hash.js "YourStrongPassword123"
ADMIN_PASSWORD_HASH=

# Secret used to sign JWT auth tokens — use a long random string in production
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# ── Email config (for contact form - configure with your SMTP details) ──
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@email.com
EMAIL_PASS=yourpassword
EMAIL_TO=info@curatdconcepts.com
